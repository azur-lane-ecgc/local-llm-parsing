{
  "name": "azur-lane-parser",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone patch notes parser for Azur Lane - fetches and processes official patch notes",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "scrape": "bun src/scrape/scrape.ts && bun check",
    "process": "bun src/opencode/opencode.ts && bun check",
    "wiki": "bun src/wiki/wiki-patch-notes.ts",
    "check": "oxlint --fix . && oxfmt --no-error-on-unmatched-pattern .",
    "submodule": "git submodule update --recursive --remote",
    "prepare": "bun run submodule && lefthook install"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "mwn": "^3.0.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
