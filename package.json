{
  "name": "azur-lane-parser",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone patch notes parser for Azur Lane - fetches and processes official patch notes",
  "type": "module",
  "module": "main.ts",
  "scripts": {
    "main": "bun run scrape && bun run process",
    "scrape": "bun main.ts -s && bun check",
    "process": "bun main.ts -o && bun check",
    "wiki": "bun main.ts -w",
    "check": "oxlint --fix . && oxfmt --no-error-on-unmatched-pattern .",
    "submodule": "git submodule update --recursive --remote",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.27",
    "cheerio": "^1.2.0",
    "mwn": "^3.0.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
