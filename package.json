{
  "name": "azur-lane-parser",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone patch notes parser for Azur Lane - fetches and processes official patch notes",
  "type": "module",
  "scripts": {
    "prepare": "bun run submodule && lefthook install",
    "check": "oxlint --fix . && oxfmt --no-error-on-unmatched-pattern .",
    "submodule": "git submodule update --recursive --remote",
    "test": "vitest run",
    "scrape": "bun scrape/scrape.ts && bun check",
    "patch-notes:p": "bun patch-notes/run.ts && bun check",
    "patch-notes:w": "bun patch-notes/wiki.ts",
    "server-news:p": "bun server-news-list/run.ts && bun check",
    "server-news:w": "bun server-news-list/wiki.ts"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "mwn": "^3.0.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
