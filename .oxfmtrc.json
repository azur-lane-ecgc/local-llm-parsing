{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "all",
  "useTabs": false,
  "tabWidth": 2,
  "endOfLine": "lf",
  "ignorePatterns": [
    "**/node_modules/**",
    "bun.lock",
    "package.json",
    "AzurLaneData"
  ]
}
