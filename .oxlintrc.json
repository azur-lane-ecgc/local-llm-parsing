{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "bun.lock",
    "package.json",
    "AzurLaneData"
  ],
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "jsdoc",
    "node",
    "promise"
  ]
}
